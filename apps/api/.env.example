# Core runtime (required in production)
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://neondb_owner:replace-with-neon-password@ep-your-project-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
JWT_SECRET=replace-with-64-plus-char-random-jwt-secret
ADMIN_SECRET=replace-with-64-plus-char-random-admin-secret
CORS_ORIGIN=https://opstreet-web-xiv9.vercel.app
AUTH_DOMAIN=opstreet-web-xiv9.vercel.app

# Auth/dev behavior
DEV_AUTH_HEADER_FALLBACK=false

# OPNet provider + health (recommended)
OPNET_RPC_URL=https://your-opnet-rpc.example.com
OPNET_PROVIDER_TIMEOUT_MS=15000
STRICT_OPNET_STARTUP=true

# OPNet explorer/data sources (optional overrides)
OPNET_EXPLORER_URL=https://testnet.opnet.org
OPNET_MEMPOOL_URL=
OPNET_VM_URL=

# Launch + pool + shop live addresses (required for live launch/shop flows)
# Verified OP_NET testnet MotoSwap addresses (confirmed 2026-03-13)
MOTOSWAP_FACTORY_ADDRESS=0xa02aa5ca4c307107484d5fb690d811df1cf526f8de204d24528653dcae369a0f
MOTOSWAP_ROUTER_ADDRESS=0x0e6ff1f2d7db7556cb37729e3738f4dae82659b984b2621fab08e1111b1b937a
SHOP_OP721_COLLECTION=
# Leave blank unless you have separately verified an OP_NET testnet TBTC contract.
OPNET_TBTC_CONTRACT_ADDRESS=

# Interaction tuning (optional)
OPNET_INTERACTION_FEE_RATE=5
OPNET_INTERACTION_MAX_SPEND=50000

# Buy quote conversion rates (optional)
PILL_SATS_RATE=70000
MOTO_SATS_RATE=65000

# Project creation throttles (optional)
CREATE_PROJECT_DAILY_LIMIT=3
CREATE_PROJECT_IP_DAILY_LIMIT=20

# Market indexer tuning (optional)
MARKET_INDEX_MAX_STALENESS_MS=600000

# Watch event notifications (optional)
APP_URL=https://opstreet-web-xiv9.vercel.app
DISCORD_WEBHOOK_URL=

# Deployer runtime (optional; only needed for automated deploy tooling)
ASC_BIN=
ASC_VERSION_PREFIX=0.29
OPNET_MNEMONIC=

# Bonding curve fee recipient (required to enable BONDING_CURVE launch type).
# Receives 5_000 atomic MOTO launch fee per new curve + 1% of all buy/sell volume.
# Must be set before any BONDING_CURVE project can call pool-create-intent.
# Note: graduation threshold (1_000_000_000), launch fee (5_000), creator reward
# (10_000), virtual MOTO reserve (100_000_000), and fee BPS (100=1%) are constants
# baked into each generated contract at scaffold time — not configurable here.
OPNET_FEE_RECIPIENT=
