generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  ticker         String
  decimals       Int       @default(18)
  maxSupply      String    @default("1000000000")
  description    String
  linksJson      String    @default("{}")
  iconUrl        String?
  status         String    @default("DRAFT")
  contractAddress String?
  network        String    @default("testnet")
  deployTx       String?
  buildHash      String?
  sourceRepoUrl  String?
  riskScore      Int?
  riskCardJson   String?
  pledgeCount    Int       @default(0)
  viewCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  checkRuns   CheckRun[]
  watchEvents WatchEvent[]

  @@index([status])
  @@index([pledgeCount])
}

model CheckRun {
  id         String   @id @default(cuid())
  projectId  String
  type       String
  status     String   @default("PENDING")
  outputJson String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model WatchEvent {
  id          String   @id @default(cuid())
  projectId   String
  severity    String   @default("INFO")
  title       String
  detailsJson String?
  txId        String?
  /// M9: Deduplication key — watcher sets this to prevent spam on recurring conditions.
  /// Format: "<rule-code>:<projectId>" e.g. "CODE_CHANGE:clxxx". If an unresolved event
  /// with the same dedupKey exists for this project within 24 h, the POST is skipped.
  dedupKey    String?
  /// M9: Set to true when the triggering condition is no longer active.
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, dedupKey])
}
